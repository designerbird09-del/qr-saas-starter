**/prisma/generated/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ---- Caches ----
.vite/
.cache/
.eslintcache
*.tsbuildinfo

# ---- Editor / OS ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.user

# ---- Misc ----
coverage/
tmp/
